{"abstract":[{"text":"Discord-style session-resume client. Runs as an actor so callers don’t","type":"text"},{"type":"text","text":" "},{"type":"text","text":"have to worry about thread-safety; you can poke it from your transport"},{"text":" ","type":"text"},{"type":"text","text":"task and from the main actor freely."}],"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/ResumeKit\/documentation\/ResumeKit\/SessionCoordinator"},"metadata":{"role":"symbol","modules":[{"name":"ResumeKit"}],"externalID":"s:9ResumeKit18SessionCoordinatorC","roleHeading":"Class","title":"SessionCoordinator","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"kind":"identifier","text":"SessionCoordinator"}],"navigatorTitle":[{"kind":"identifier","text":"SessionCoordinator"}],"symbolKind":"class"},"primaryContentSections":[{"kind":"declarations","declarations":[{"languages":["swift"],"platforms":["macOS"],"tokens":[{"text":"actor","kind":"keyword"},{"text":" ","kind":"text"},{"text":"SessionCoordinator","kind":"identifier"}]}]},{"kind":"content","content":[{"type":"heading","level":1,"text":"Architecture","anchor":"Architecture"},{"type":"paragraph","inlineContent":[{"text":"The coordinator owns three pieces of state:","type":"text"}]},{"type":"orderedList","items":[{"content":[{"inlineContent":[{"type":"text","text":"The in-memory "},{"code":"state","type":"codeVoice"},{"type":"text","text":" (handshaking \/ replaying \/ live \/ disconnected)."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"type":"text","text":"A persistent "},{"type":"codeVoice","code":"(sessionId, lastSeq)"},{"type":"text","text":" cursor in "},{"type":"codeVoice","code":"SessionStorage"},{"type":"text","text":"."}],"type":"paragraph"}]},{"content":[{"inlineContent":[{"text":"A heartbeat timer that fires while the connection is healthy.","type":"text"}],"type":"paragraph"}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"It does "},{"inlineContent":[{"text":"not","typ